{
  "name": "discord-media-exporter",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "User-initiated helper for downloading visible Discord media.",
  "packageManager": "pnpm@9.7.0",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "prepare": "wxt prepare",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "release:verify": "node scripts/verify-release.mjs",
    "release:checksum": "node scripts/write-checksum.mjs",
    "release:prepare": "node scripts/prepare-release.mjs"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "happy-dom": "20.10.6",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10",
    "wxt": "0.20.27"
  }
}
